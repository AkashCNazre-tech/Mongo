<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/person">
                <i class="bi bi-people-fill me-2"></i>
                Person Management System
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/person">
                            <i class="bi bi-list-ul me-1"></i>
                            All People
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/person/create">
                            <i class="bi bi-person-plus-fill me-1"></i>
                            Add Person
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container my-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    <i class="bi bi-people me-2"></i>
                    People Directory
                </h4>
                <a href="/person/create" class="btn btn-light btn-sm">
                    <i class="bi bi-plus-circle me-1"></i>
                    Add New Person
                </a>
            </div>

            <div class="card-body">
                <% if (people.length===0) { %>
                    <div class="alert alert-info text-center" role="alert">
                        <i class="bi bi-info-circle me-2"></i>
                        No people found. <a href="/person/create" class="alert-link">Add your first person</a>
                    </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover table-striped align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Name</th>
                                        <th scope="col">Age</th>
                                        <th scope="col">Gender</th>
                                        <th scope="col">Mobile Number</th>
                                        <th scope="col" class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% people.forEach((person, index)=> { %>
                                        <tr>
                                            <th scope="row">
                                                <%= index + 1 %>
                                            </th>
                                            <td>
                                                <%= person.name %>
                                            </td>
                                            <td>
                                                <%= person.age %>
                                            </td>
                                            <td>
                                                <% if (person.gender==='Male' ) { %>
                                                    <i class="bi bi-gender-male text-primary"></i>
                                                    <% } else if (person.gender==='Female' ) { %>
                                                        <i class="bi bi-gender-female text-danger"></i>
                                                        <% } else { %>
                                                            <i class="bi bi-gender-ambiguous text-secondary"></i>
                                                            <% } %>
                                                                <%= person.gender %>
                                            </td>
                                            <td>
                                                <i class="bi bi-phone me-1"></i>
                                                <%= person.mobileNumber %>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a href="/person/edit/<%= person._id %>"
                                                        class="btn btn-sm btn-warning" title="Edit">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </a>
                                                    <form action="/person/delete/<%= person._id %>" method="POST"
                                                        class="d-inline"
                                                        onsubmit="return confirm('Are you sure you want to delete <%= person.name %>?');">
                                                        <button type="submit" class="btn btn-sm btn-danger"
                                                            title="Delete">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <div class="mt-3 text-muted">
                            <small>
                                <i class="bi bi-info-circle me-1"></i>
                                Total: <%= people.length %>
                                    <%= people.length===1 ? 'person' : 'people' %>
                            </small>
                        </div>
                        <% } %>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-light text-center text-muted py-4 mt-5">
        <div class="container">
            <p class="mb-0">
                <i class="bi bi-code-slash"></i>
                Person Management System &copy; 2026
            </p>
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>